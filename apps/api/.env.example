# PostgreSQL connection string
DATABASE_URL=postgresql://gallero:gallero_dev@localhost:5433/gallero

# Redis connection string (required)
REDIS_URL=redis://localhost:6379

# JWT secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=dev_access_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Sentry (optional, only in production)
SENTRY_DSN=

# Server
PORT=3000
NODE_ENV=development

# CORS allowed origins (comma-separated, extra origins beyond default localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cookie domain (production only, e.g. .gallero.app)
# COOKIE_DOMAIN=
