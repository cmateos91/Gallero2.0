# API base URL
VITE_API_URL=http://localhost:3000

# WebSocket URL
VITE_WS_URL=ws://localhost:3000/ws/pvp

# Google OAuth client ID (optional)
VITE_GOOGLE_CLIENT_ID=

# Sentry DSN (optional, only in production)
VITE_SENTRY_DSN=

# Enable dev hatch button (development only)
VITE_ENABLE_DEV_HATCH=false
